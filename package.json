{
  "name": "aws-cdk-template",
  "version": "0.1.0",
  "bin": {
    "aws-cdk-template": "bin/aws-cdk-template.js"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "cdk:prd": "pnpm with-env:prd cdk --context env=prd",
    "cdk:stg": "pnpm with-env:stg cdk --context env=stg",
    "cdk:dev": "pnpm with-env:dev cdk --context env=dev",
    "test:prd": "pnpm with-env:prd jest",
    "test:stg": "pnpm with-env:stg jest",
    "test:dev": "pnpm with-env:dev jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.ts\" --cache",
    "format:fix": "prettier --write \"**/*.ts\" --cache",
    "clean": "rm -rf node_modules",
    "typecheck": "tsc --noEmit",
    "with-env:prd": "dotenv -e .env.prd --",
    "with-env:stg": "dotenv -e .env.stg --",
    "with-env:dev": "dotenv -e .env.dev --"
  },
  "dependencies": {
    "aws-cdk-lib": "2.254.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "aws-cdk": "2.1121.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-awscdk": "^4.3.3",
    "eslint-plugin-n": "^18.0.1",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3",
    "zod": "^4.4.3"
  }
}
